#!/usr/bin/env bash
set -x
exec 1>&2

mkdir -p /etc/X11/xorg.conf.d/
cat <<CFG > /etc/X11/xorg.conf.d/20-modesetting.conf
Section "ServerFlags"
  Option "AutoAddGPU" "false"
EndSection

Section "Device"
  Identifier "GPU0"
  Driver "modesetting"
  Option "kmsdev" "/dev/dri/by-path/gpu-card"
EndSection
CFG


mkdir -p /etc/xdg/openbox
cat <<CFG > /etc/xdg/openbox/rc.xml
<?xml version="1.0" encoding="UTF-8"?>

<!-- Do not edit this file, it will be overwritten on install.
        Copy the file to $HOME/.config/openbox/ instead. -->

<openbox_config xmlns="http://openbox.org/3.4/rc"
		xmlns:xi="http://www.w3.org/2001/XInclude">
<applications>
  <application class="*">
    <maximized>yes</maximized>
  </application>
</applications>

</openbox_config>
CFG

mkdir -p /etc/profile.d/
cat <<CFG > /etc/profile.d/actcast.sh
export GTK_IM_MODULE=fcitx
export QT_IM_MODULE=fcitx
export XMODIFIERS=@im=fcitx
export SDL_IM_MODULE=fcitx
CFG

useradd -m idein \
 && (getent group render || groupadd -r render) \
 && usermod -aG render idein \
 && usermod -aG render root

sed -i 's/# ja_JP.UTF-8 UTF-8/ja_JP.UTF-8 UTF-8/' /etc/locale.gen && locale-gen

export LANG=ja_JP.UTF-8
export LC_ALL=ja_JP.UTF-8
export KEYLAYOUT=jp

export DISPLAY=:0
export VT=7

cp main.py /home/idein/main.py
chown -R idein:idein /home/idein

exec ./start-x.sh python3 /home/idein/main.py
